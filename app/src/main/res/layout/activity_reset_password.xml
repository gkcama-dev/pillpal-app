<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    tools:context=".activity.ResetPasswordActivity">

    <View
        android:id="@+id/bg_top_circle"
        android:layout_width="297dp"
        android:layout_height="295dp"
        android:layout_marginTop="-111dp"
        android:layout_marginEnd="-30dp"
        android:background="@drawable/bg_circle_soft"
        android:alpha="0.1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="100dp"
        android:src="@drawable/logo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvResetTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:fontFamily="@font/quicksand_bold"
        android:text="Reset Password"
        android:textColor="@color/primaryPurple"
        android:textSize="30sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imgLogo" />

    <TextView
        android:id="@+id/tvSubTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="40dp"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/quicksand_semibold"
        android:gravity="center"
        android:text="Please enter your email address to request a password reset"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvResetTitle" />

    <EditText
        android:id="@+id/etEmailReset"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginHorizontal="25dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/custom_input_search"
        android:backgroundTint="?attr/colorSurface"
        android:fontFamily="@font/quicksand_semibold"
        android:hint="geeth@gmail.com"
        android:inputType="textEmailAddress"
        android:paddingHorizontal="20dp"
        android:textColor="?android:attr/textColorPrimary"
        android:textColorHint="@color/dark_text_secondary"
        app:layout_constraintTop_toBottomOf="@id/tvSubTitle" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnResetPassword"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginHorizontal="30dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/button_bg_purple"
        android:backgroundTint="@color/primaryPurple"
        android:fontFamily="@font/quicksand_bold"
        android:text="Send Reset Link"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/etEmailReset" />

    <ImageView
        android:id="@+id/ic_bottom_triangle"
        android:layout_width="25dp"
        android:layout_height="24dp"
        android:layout_marginStart="110dp"
        android:layout_marginBottom="120dp"
        android:rotation="-102"
        android:alpha="0.2"
        android:src="@drawable/ic_triangle_shape"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>