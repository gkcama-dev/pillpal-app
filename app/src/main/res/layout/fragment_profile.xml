<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"> <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:layout_marginBottom="24dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/profile_image_large"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:padding="2dp"
            android:src="@drawable/avatar"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/CircleImage"
            app:strokeColor="@color/primaryPurple"
            app:strokeWidth="2dp" />
    </LinearLayout>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Full name" android:fontFamily="@font/quicksand_bold"
        android:textColor="?android:attr/textColorSecondary" />
    <EditText
        android:id="@+id/et_profile_full_name"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:background="@drawable/custom_input_search"
        android:backgroundTint="?attr/colorSurface"
        android:fontFamily="@font/quicksand_semibold"
        android:hint="e.g. Geeth Kalhara"
        android:inputType="textPersonName"
        android:paddingStart="15dp"
        android:textColor="?android:attr/textColorPrimary"
        android:textColorHint="?android:attr/textColorSecondary"
        android:layout_marginBottom="16dp"
        android:layout_marginTop="4dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Phone Number" android:fontFamily="@font/quicksand_bold"
        android:textColor="?android:attr/textColorSecondary" />
    <EditText
        android:id="@+id/et_profile_mobile"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:background="@drawable/custom_input_search"
        android:backgroundTint="?attr/colorSurface"
        android:fontFamily="@font/quicksand_semibold"
        android:hint="e.g. +94771234567"
        android:inputType="phone"
        android:paddingStart="15dp"
        android:textColor="?android:attr/textColorPrimary"
        android:textColorHint="?android:attr/textColorSecondary"
        android:layout_marginBottom="16dp"
        android:layout_marginTop="4dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Address" android:fontFamily="@font/quicksand_bold"
        android:textColor="?android:attr/textColorSecondary" />
    <EditText
        android:id="@+id/et_profile_address"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/custom_input_search"
        android:backgroundTint="?attr/colorSurface"
        android:fontFamily="@font/quicksand_semibold"
        android:hint="Enter your home address"
        android:gravity="top|start"
        android:padding="15dp"
        android:textColor="?android:attr/textColorPrimary"
        android:textColorHint="?android:attr/textColorSecondary"
        android:layout_marginBottom="16dp"
        android:layout_marginTop="4dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="NIC / Passport" android:fontFamily="@font/quicksand_bold"
        android:textColor="?android:attr/textColorSecondary" />
    <EditText
        android:id="@+id/et_profile_nic"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:background="@drawable/custom_input_search"
        android:backgroundTint="?attr/colorSurface"
        android:fontFamily="@font/quicksand_semibold"
        android:hint="Enter NIC or Passport number"
        android:inputType="text"
        android:paddingStart="15dp"
        android:textColor="?android:attr/textColorPrimary"
        android:textColorHint="?android:attr/textColorSecondary"
        android:layout_marginBottom="16dp"
        android:layout_marginTop="4dp"/>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Emergency Contacts" android:fontFamily="@font/quicksand_bold"
        android:textColor="?android:attr/textColorSecondary" />
    <EditText
        android:id="@+id/et_profile_emergency"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:background="@drawable/custom_input_search"
        android:backgroundTint="?attr/colorSurface"
        android:fontFamily="@font/quicksand_semibold"
        android:hint="Enter emergency contact number"
        android:inputType="phone"
        android:paddingStart="15dp"
        android:textColor="?android:attr/textColorPrimary"
        android:textColorHint="?android:attr/textColorSecondary"
        android:layout_marginBottom="30dp"
        android:layout_marginTop="4dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_update_profile"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:text="Update"
            android:fontFamily="@font/quicksand_bold"
            app:cornerRadius="12dp"
            android:backgroundTint="@color/primaryPurple"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_logout_profile"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            android:text="Logout"
            android:fontFamily="@font/quicksand_bold"
            app:cornerRadius="12dp"
            android:backgroundTint="#F44336"
            app:icon="@drawable/logout"
            app:iconGravity="textStart"/>
    </LinearLayout>

</LinearLayout>
</ScrollView>