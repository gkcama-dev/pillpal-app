<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginBottom="24dp"
        android:src="@drawable/login"
        app:tint="@color/primaryPurple" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/quicksand_bold"
        android:text="Order Placed Successfully!"
        android:textAlignment="center"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="22sp" />

    <TextView
        android:id="@+id/tv_order_id_success"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/quicksand_semibold"
        android:text="Order ID: #ORD-123456"
        android:textColor="@color/primaryPurple"
        android:textSize="16sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fontFamily="@font/quicksand_semibold"
        android:text="Your order request has been sent to the pharmacist for approval. You will receive a notification once it is verified."
        android:textAlignment="center"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="14sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_view_history"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="40dp"
        android:backgroundTint="@color/primaryPurple"
        android:fontFamily="@font/quicksand_bold"
        android:text="View Order History"
        app:cornerRadius="12dp" />

    <TextView
        android:id="@+id/btn_go_home"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fontFamily="@font/quicksand_bold"
        android:text="Back to Home"
        android:textColor="@color/secondaryPurple"
        android:textSize="16sp" />

</LinearLayout>